# Copiá este archivo como .env y completalo
# Si dejás vacía la API key, el módulo AFIP funciona en modo demo

# Token de afipsdk.com (gratis hasta cierto volumen)
# Obtenerlo en: https://afipsdk.com/  -> registrarse -> sección API
AFIPSDK_TOKEN=

# Para datos reales de producción:
# AFIPSDK_ENV=prod
# AFIPSDK_TAX_ID=CUIT_REPRESENTANTE_SIN_GUIONES
# Local: usar paths a los archivos
# AFIPSDK_CERT=/ruta/al/certificado.crt
# AFIPSDK_KEY=/ruta/a/la/clave.key
# Deploy cloud: usar contenido PEM directo o base64
# AFIPSDK_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# AFIPSDK_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# AFIPSDK_CERT_B64=certificado_en_base64
# AFIPSDK_KEY_B64=clave_en_base64

# Si seteás usuario y contraseña, el sitio queda protegido con Basic Auth
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Carpeta donde están los padrones provinciales mensuales
PADRONES_DIR=./padrones

# Carpeta donde se guardan los Excel generados
SALIDAS_DIR=./salidas

# Supabase MVP server-side. No exponer SERVICE_ROLE_KEY en frontend.
# SUPABASE_URL=https://szpmuxncfdbzpfkngizk.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=menter-fiscal
# SUPABASE_TENANT_SLUG=ccu
